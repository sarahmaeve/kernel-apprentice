# Pinned tool/source versions for the workbench — the single source of truth.
# Sourced by harness/lib.sh. Change a value here to re-pin everything downstream.
#
# WHY PIN (DESIGN.md §4, macOS notes): "Internal APIs and line numbers churn
# between releases; unpinned source makes lesson references rot." Lesson READMEs
# cite file:line against the kernel below, so bumping KERNEL_VERSION means
# re-checking those citations.

# --- Linux kernel ---------------------------------------------------------
# 6.18 is the newest LTS: released 2025-11-30, maintained through Dec 2028.
# (Verified against kernel.org/category/releases.html on 2026-05-31. Everything
# newer — 6.19, mainline 7.0 — is non-LTS and would rot the curriculum faster.)
# 6.18.33 is the current point release in the 6.18.y line.
KERNEL_VERSION=6.18.33
KERNEL_BRANCH=v6.x
KERNEL_TARBALL="linux-${KERNEL_VERSION}.tar.xz"
KERNEL_URL="https://cdn.kernel.org/pub/linux/kernel/${KERNEL_BRANCH}/${KERNEL_TARBALL}"

# sha256 of the tarball above. Left blank deliberately: we do NOT guess hashes.
# On first build, harness/build-kernel.sh downloads, computes the real hash,
# prints it, and refuses to continue until you paste it here (or pass
# ALLOW_UNPINNED=1 for a one-off). This pins the supply chain, not a guess.
KERNEL_SHA256=""

# --- Guest architecture (PINNED for portability) --------------------------
# The guest is x86_64 for EVERY contributor regardless of host CPU, so lesson
# file:line references and code paths are identical everywhere. The workbench
# image is pinned to linux/amd64 to match (see Makefile PLATFORM). Native on
# Intel/x86 Linux; emulated-but-identical on Apple Silicon (DESIGN.md §4).
GUEST_ARCH=x86_64

# --- Guest userspace ------------------------------------------------------
# BusyBox comes prebuilt + static from the Debian 'busybox-static' package in
# the workbench image, so there is no BusyBox source build to pin here.
