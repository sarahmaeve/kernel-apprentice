# Kernel config fragment for the tutorial guest.
#
# Merged ON TOP OF `make defconfig` (x86_64) by build-kernel.sh via
# scripts/kconfig/merge_config.sh. Starting from defconfig (which already boots
# under QEMU with an 8250 serial console) and adding only what the lessons need
# is the ROBUST choice: it boots first try. Speed-trimming the config to shrink
# the one-time build is a deliberate later optimization, not a Phase 1 risk.

# --- Console / boot: serial console for headless capture (-nographic ttyS0) ---
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y
CONFIG_EARLY_PRINTK=y

# --- Root filesystem via BusyBox initramfs (no disk needed for fast drills) ---
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# --- Loadable modules (lesson 02 builds + insmods an out-of-tree .ko) ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
# Disable symbol-version CRCs so a freshly-built out-of-tree .ko loads without
# needing a full in-tree `make modules` to generate Module.symvers. We build the
# module against this exact tree, so version skew isn't a risk.
# CONFIG_MODVERSIONS is not set

# --- Observability surfaces (lessons 02+ and the Wheel lean on these) ---
CONFIG_DEBUG_FS=y
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_EVENTS=y

# --- Task state / limits / oom visibility for the "Works on my laptop" wheel ---
CONFIG_PROC_PAGE_MONITOR=y

# NOTE: KASAN, lockdep, and other heavy debug options are intentionally NOT here.
# They slow boot/build substantially and are enabled per-scenario later (e.g. the
# "driver that oopses" wheel scenario ships its own KASAN config overlay).
