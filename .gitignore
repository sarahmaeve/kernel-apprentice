# Local-only environment notes (machine specs, not for the shared repo).
userspecs.txt

# Build artifacts — all rebuilt from pinned sources, never committed.
# The kernel source tree + images live here and persist across colima/container
# restarts because this dir is bind-mounted from the host (see DESIGN.md §4).
harness/.build/
harness/.cache/

# Compiled module / object leftovers (lessons build out-of-tree .ko's).
*.o
*.ko
*.mod
*.mod.c
*.cmd
.*.cmd
modules.order
Module.symvers

# Boot images and captured serial logs.
*.cpio.gz
*.bzImage
*.serial.log

# Generated, derived dashboard status (regenerated by `make status`; never committed).
assets/status.js
